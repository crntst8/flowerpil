# Global static headers applied by Cloudflare Pages
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

# Never cache HTML shells (fresh app on reload)
/*.html
  Cache-Control: no-store, max-age=0, must-revalidate

# Root index (explicit)
/
  Cache-Control: no-store, max-age=0, must-revalidate

# PWA and icons should not hard-cache
/manifest.json
  Cache-Control: no-cache

/icons/*
  Cache-Control: no-cache

/favicon.ico
  Cache-Control: no-cache

# Fingerprinted assets can be cached long-term
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Uploaded images (content-addressed, immutable)
/uploads/*
  Cache-Control: public, max-age=31536000, immutable
  Vary: Accept

# Dynamic sitemap - moderate caching, allow indexing
/sitemap.xml
  Cache-Control: public, max-age=3600, s-maxage=3600
  Content-Type: application/xml; charset=utf-8
  X-Robots-Tag: all

