{
  "name": "flowerpil",
  "version": "1.0.0",
  "description": "Mobile-first playlist curation platform",
  "main": "server/index.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server:pm2\" \"npm run client:dev\"",
    "dev:pi": "concurrently \"npm run server:pm2\" \"npm run client:dev:pi\"",
    "server:pm2": "pm2 start ecosystem.config.cjs --env development",
    "server:stop": "pm2 stop flowerpil-api",
    "server:restart": "pm2 restart flowerpil-api",
    "server:logs": "pm2 logs flowerpil-api",
    "server:dev": "nodemon server/index.js",
    "worker:token-refresh": "pm2 start ecosystem.config.cjs --only token-refresh-worker-dev",
    "worker:token-refresh:stop": "pm2 stop token-refresh-worker-dev",
    "worker:token-refresh:logs": "pm2 logs token-refresh-worker-dev",
    "client:dev": "vite --config vite.config.js",
    "client:dev:pi": "vite --config vite.config.dev.js",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server/index.js",
    "db:init": "node scripts/init-db.js",
    "db:migrate": "node server/database/migrate.js up",
    "db:setup-post-tag": "node scripts/setup-post-content-tag.js",
    "setup:env": "node server/dev/setupEnv.js",
    "seed:users": "node server/dev/seedTestUsers.js",
    "test:auth": "node server/dev/testAuth.js",
    "test:errors": "node server/dev/test-error-reporting.js",
    "test:errors:all": "node server/dev/test-error-reporting.js all",
    "dev:users:list": "node server/dev/manageTestUsers.js list",
    "dev:users:clear": "node server/dev/manageTestUsers.js clear",
    "locks:reset": "node scripts/reset-account-locks.js",
    "locks:list": "node scripts/reset-account-locks.js --list",
    "locks:clean": "node scripts/reset-account-locks.js --expired",
    "admin:dashboard": "node server/scripts/admin-dashboard.js",
    "tester:toggle": "node server/scripts/toggleTesterFlag.js",
    "module:create": "node scripts/create-module.js",
    "icons:preview": "node scripts/update-icons.js --dry-run --verbose",
    "icons:update": "node scripts/update-icons.js --execute --verbose",
    "images:scan": "node scripts/image-cleanup-tool.js scan",
    "images:stats": "node scripts/image-cleanup-tool.js stats",
    "images:find-orphaned": "node scripts/image-cleanup-tool.js find-orphaned",
    "images:cleanup-orphans-dry-run": "node scripts/image-cleanup-tool.js cleanup-orphans-dry-run",
    "images:cleanup-orphans": "node scripts/image-cleanup-tool.js cleanup-orphans",
    "images:delete": "node scripts/image-cleanup-tool.js delete",
    "images:validate": "node scripts/image-cleanup-tool.js validate",
    "images:help": "node scripts/image-cleanup-tool.js help",
    "images:regenerate": "node --env-file=.env scripts/regenerate-images.js",
    "images:regenerate:dry-run": "node --env-file=.env scripts/regenerate-images.js --dry-run",
    "images:regenerate:test": "node --env-file=.env scripts/regenerate-images.js --dry-run --limit 5",
    "logging:dev": "node logging-server/index.js",
    "style:monitor": "node scripts/style/monitoring-pipeline.cjs",
    "style:validate": "node scripts/style/code-example-validator.cjs",
    "style:frequencies": "node scripts/style/pattern-frequency-scanner.cjs",
    "style:check": "npm run style:monitor && npm run style:validate",
    "style:check:quick": "npm run style:validate -- --quick && npm run style:frequencies -- --no-save",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:unit:backend": "vitest run --config vitest.config.backend.js",
    "test:unit:frontend": "vitest run --config vitest.config.frontend.js",
    "test:unit:watch": "vitest",
    "test:unit:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:coverage": "vitest run --coverage",
    "test:coverage:backend": "vitest run --config vitest.config.backend.js --coverage",
    "test:coverage:frontend": "vitest run --config vitest.config.frontend.js --coverage",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.{js,jsx,json,css}\""
  },
  "keywords": [
    "playlist",
    "music",
    "curation"
  ],
  "author": "Flowerpil",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-code": "^1.0.88",
    "@aws-sdk/client-s3": "^3.922.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@lexical/html": "^0.40.0",
    "@lexical/react": "^0.40.0",
    "@lexical/selection": "^0.40.0",
    "@openai/codex": "^0.98.0",
    "@playwright/test": "^1.54.2",
    "@tiptap/extension-color": "^3.11.0",
    "@tiptap/extension-highlight": "^3.11.0",
    "@tiptap/extension-image": "^3.11.0",
    "@tiptap/extension-link": "^3.11.0",
    "@tiptap/extension-subscript": "^3.11.0",
    "@tiptap/extension-superscript": "^3.11.0",
    "@tiptap/extension-table": "^3.11.0",
    "@tiptap/extension-table-cell": "^3.11.0",
    "@tiptap/extension-table-header": "^3.11.0",
    "@tiptap/extension-table-row": "^3.11.0",
    "@tiptap/extension-text-align": "^3.11.0",
    "@tiptap/extension-text-style": "^3.11.0",
    "@tiptap/extension-underline": "^3.11.0",
    "@tiptap/react": "^3.11.0",
    "@tiptap/starter-kit": "^3.11.0",
    "@vitest/ui": "^3.2.4",
    "archiver": "^7.0.1",
    "axios": "^1.11.0",
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^11.1.2",
    "claude": "^0.1.1",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "debug": "^4.4.1",
    "dompurify": "^3.3.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.0.1",
    "fluent-ffmpeg": "^2.1.3",
    "framer-motion": "^12.23.26",
    "helmet": "^7.1.0",
    "ioredis": "^5.8.2",
    "isomorphic-dompurify": "^2.31.0",
    "joi": "^18.0.0",
    "jsonwebtoken": "^9.0.2",
    "kill-port": "^2.0.1",
    "lexical": "^0.40.0",
    "lru-cache": "^11.2.5",
    "motion": "^12.23.25",
    "msw": "^2.10.5",
    "multer": "^1.4.5-lts.1",
    "music-metadata": "^11.8.3",
    "node-cron": "^3.0.3",
    "node-id3": "^0.2.9",
    "nodemailer": "^7.0.6",
    "npm": "^11.5.2",
    "pino": "^8.21.0",
    "pino-http": "^9.0.0",
    "pino-pretty": "^10.3.1",
    "puppeteer": "^21.0.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "qrcode.react": "^3.1.0",
    "quill": "^2.0.3",
    "react-quill-new": "^3.6.0",
    "react-rnd": "^10.5.2",
    "recharts": "^3.7.0",
    "sharp": "^0.33.4",
    "sqlite3": "^5.1.7",
    "supertest": "^7.1.4",
    "use-places-autocomplete": "^4.0.1",
    "uuid": "^10.0.0",
    "vitest": "^3.2.4",
    "winston": "^3.17.0",
    "wrangler": "^4.47.0",
    "ws": "^8.19.0",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.1",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^3.2.4",
    "baseline-browser-mapping": "^2.9.19",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.34.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.7.0",
    "jsdom": "^27.0.1",
    "nodemon": "^3.1.0",
    "prettier": "^3.3.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1",
    "styled-components": "^6.1.11",
    "vite": "^5.3.1"
  }
}
