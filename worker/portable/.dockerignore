# Node modules (will be installed during build)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files (should be mounted or provided at runtime)
.env
.env.local
.env.*.local

# Git
.git/
.gitignore

# Documentation (not needed in container)
README.md
DEPLOYMENT.md

# Development files
*.md
.vscode/
.idea/
*.swp
*.swo
*~

# Test files
test/
tests/
*.test.js
*.spec.js

# CI/CD
.github/
.gitlab-ci.yml

# Docker files (not needed inside container)
Dockerfile*
docker-compose*.yml
.dockerignore

# OS files
.DS_Store
Thumbs.db

# Logs
logs/
*.log

# Temporary files
tmp/
temp/
