# =============================================================================
# Portable Linking Worker - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# All sensitive values should be kept secure and never committed to git
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED: API Connection
# -----------------------------------------------------------------------------

# Base URL of the core API (include protocol and port if not standard)
# Examples:
#   - Production: https://api.flowerpil.io
#   - Staging: https://staging-api.flowerpil.io
#   - Local dev: http://localhost:3000
LINKING_API_BASE=https://api.flowerpil.io

# Worker authentication key (must match LINKING_WORKER_KEYS on API server)
# Generate a secure random string for production
# Example: openssl rand -hex 32
LINKING_WORKER_KEY=your-secure-worker-key-here

# -----------------------------------------------------------------------------
# REQUIRED: Platform Credentials (at least one platform recommended)
# -----------------------------------------------------------------------------

# Spotify API Credentials
# Get from: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Tidal API Credentials
# Contact Tidal for API access
TIDAL_CLIENT_ID=
TIDAL_CLIENT_SECRET=

# Apple Music API Credentials (requires Apple Developer account)
# Get from: https://developer.apple.com/account/resources/authkeys/list
APPLE_MUSIC_TEAM_ID=
APPLE_MUSIC_KEY_ID=
# Path to .p8 private key file OR base64-encoded key content
APPLE_MUSIC_PRIVATE_KEY_PATH=./AuthKey_XXXXXXXXXX.p8
# Alternative: provide key content directly (base64 or raw)
# APPLE_MUSIC_PRIVATE_KEY=

# Apple Music storefront (2-letter country code, default: us)
# See: https://developer.apple.com/documentation/applemusicapi/storefront
APPLE_MUSIC_STOREFRONT=us

# -----------------------------------------------------------------------------
# OPTIONAL: Worker Configuration
# -----------------------------------------------------------------------------

# Unique identifier for this worker instance
# Default: hostname-pid (auto-generated)
# LINKING_WORKER_ID=worker-01

# Restrict worker to a specific playlist ID (for dedicated workers)
# Default: process all playlists
# LINKING_PLAYLIST_ID=123

# Number of tracks to lease per batch (1-50)
# Default: 5
# LINKING_BATCH_SIZE=5

# Worker poll interval in milliseconds (10-5000)
# Default: 100
# LINKING_POLL_INTERVAL_MS=100

# Heartbeat interval in seconds (10-300)
# Default: 60
# LINKING_HEARTBEAT_INTERVAL_SEC=60

# -----------------------------------------------------------------------------
# OPTIONAL: TLS/SSL Configuration
# -----------------------------------------------------------------------------

# Reject unauthorized TLS certificates
# Set to 0 for self-signed certificates in development
# Default: 0 (disabled)
NODE_TLS_REJECT_UNAUTHORIZED=0

# -----------------------------------------------------------------------------
# OPTIONAL: Health Check & Monitoring
# -----------------------------------------------------------------------------

# Enable health check HTTP server
# Default: true
HEALTH_CHECK_ENABLED=true

# Health check server port
# Default: 3001
HEALTH_CHECK_PORT=3001

# Enable metrics collection
# Default: true
METRICS_ENABLED=true

# -----------------------------------------------------------------------------
# OPTIONAL: Logging Configuration
# -----------------------------------------------------------------------------

# Log level: debug, info, warn, error
# Default: info
LOG_LEVEL=info

# Log format: json (structured) or text (human-readable)
# Default: json
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# OPTIONAL: Advanced Settings
# -----------------------------------------------------------------------------

# Graceful shutdown timeout in milliseconds (1000-300000)
# Default: 30000 (30 seconds)
SHUTDOWN_TIMEOUT_MS=30000

# -----------------------------------------------------------------------------
# Example Configurations
# -----------------------------------------------------------------------------

# Development (local API, text logs, debug level):
# LINKING_API_BASE=http://localhost:3000
# LOG_LEVEL=debug
# LOG_FORMAT=text
# NODE_TLS_REJECT_UNAUTHORIZED=0

# Production (secure API, JSON logs, info level):
# LINKING_API_BASE=https://api.flowerpil.io
# LOG_LEVEL=info
# LOG_FORMAT=json
# NODE_TLS_REJECT_UNAUTHORIZED=1
# HEALTH_CHECK_ENABLED=true

# High-throughput worker (larger batches):
# LINKING_BATCH_SIZE=20
# LINKING_POLL_INTERVAL_MS=50

# Dedicated playlist worker:
# LINKING_PLAYLIST_ID=456
# LINKING_WORKER_ID=playlist-456-worker
